---
import type { Product } from "../lib/microcms";
import { getProductSalesStatus } from "../lib/microcms";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const status = getProductSalesStatus(product);
const isUnavailable = status === "売り切れ" || status === "期間終了";
---

<a
  href={`/products/${product.id}`}
  class:list={[
    "group block overflow-hidden rounded-lg border border-gray-200 transition hover:shadow-md",
    isUnavailable && "opacity-75 grayscale-[40%]",
  ]}
  data-roast={JSON.stringify(product.roastLevel ?? [])}
  data-recommended={product.isRecommended ? "true" : "false"}
  data-seasonal={product.isSeasonal ? "true" : "false"}
  data-sales-status={status}
>
  <div class="relative aspect-square overflow-hidden bg-gray-100">
    {product.image ? (
      <img
        src={`${product.image.url}?w=480&h=480&fit=crop`}
        alt={product.name}
        width="480"
        height="480"
        loading="lazy"
        class="h-full w-full object-cover transition-transform group-hover:scale-105"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center bg-coffee-50">
        <span class="text-4xl text-coffee-200">☕</span>
      </div>
    )}
    {isUnavailable && (
      <div class="absolute inset-0 flex items-center justify-center bg-black/40">
        <span class="rounded-md bg-white/90 px-3 py-1.5 text-sm font-bold text-gray-800">
          {status}
        </span>
      </div>
    )}
  </div>
  <div class="p-4">
    <h3 class="font-semibold text-gray-900 group-hover:text-coffee-600">
      {product.name}
    </h3>
    <div class="mt-2 flex flex-wrap gap-1.5">
      {status === "売り切れ" && (
        <span class="rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700">
          {status}
        </span>
      )}
      {status === "期間終了" && (
        <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">
          {status}
        </span>
      )}
      {status === "入荷待ち" && (
        <span class="rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700">
          {status}
        </span>
      )}
      {product.roastLevel?.map((level: string) => (
        <span class="rounded-full bg-coffee-50 px-2 py-0.5 text-xs font-medium text-coffee-700">
          {level}
        </span>
      ))}
      {product.isRecommended && (
        <span class="rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700">
          おすすめ
        </span>
      )}
      {product.isSeasonal && (
        <span class="rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">
          季節限定
        </span>
      )}
    </div>
    {product.origin && (
      <p class="mt-2 text-xs text-gray-500">産地: {product.origin}</p>
    )}
    {product.priceRange && (
      <p class="mt-1 text-sm font-medium text-gray-700">{product.priceRange}</p>
    )}
  </div>
</a>

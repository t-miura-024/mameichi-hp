---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsCard from "../../components/NewsCard.astro";
import { getNewsList } from "../../lib/microcms";

const { contents: newsList } = await getNewsList();
---

<BaseLayout
  title="お知らせ"
  description="焙煎工房 函館豆壱からのお知らせ。新着商品、イベント、営業案内などの最新情報をお届けします。"
>
  <section class="py-16">
    <div class="mx-auto max-w-content px-4">
      <h1 class="text-3xl font-bold text-gray-900">お知らせ</h1>

      {newsList.length > 0 ? (
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {newsList.map((news) => (
            <NewsCard news={news} />
          ))}
        </div>
      ) : (
        <p class="mt-8 text-sm text-gray-500">現在お知らせはありません。</p>
      )}
    </div>
  </section>
</BaseLayout>

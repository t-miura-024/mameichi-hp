---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import ProductCard from "../components/ProductCard.astro";
import NewsCard from "../components/NewsCard.astro";
import { getProductList, getNewsList, isProductAvailable } from "../lib/microcms";

const { contents: allProducts } = await getProductList();
const recommendedProducts = allProducts
  .filter((p) => p.isRecommended && isProductAvailable(p))
  .slice(0, 4);

const { contents: latestNews } = await getNewsList(3);
---

<BaseLayout title="焙煎工房 函館豆壱">
  <!-- Hero -->
  <HeroCarousel
    slides={[
      {
        type: "image",
        src: "/images/hero/yakei.png",
        alt: "焙煎工房 函館豆壱",
      },
      { type: "video", src: "/images/hero/baisen.mp4" },
      {
        type: "image",
        src: "/images/hero/drip.png",
        alt: "コーヒー豆",
      },
    ]}
    interval={6000}
  />

  <!-- About snippet -->
  <section class="py-16">
    <div class="mx-auto max-w-content px-4 text-center">
      <h2 class="text-2xl font-bold text-gray-900">お店について</h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-600">
        函館の地で、厳選した生豆を一つひとつ丁寧に焙煎しています。
        豆の個性を最大限に引き出し、香り高いコーヒー豆をお届けします。
      </p>
      <a
        href="/about"
        class="mt-6 inline-block rounded-md bg-coffee-600 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-coffee-700"
      >
        詳しく見る
      </a>
    </div>
  </section>

  <!-- Products pickup -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-content px-4">
      <h2 class="text-center text-2xl font-bold text-gray-900">おすすめ商品</h2>
      {
        recommendedProducts.length > 0 ? (
          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {recommendedProducts.map((product) => (
              <ProductCard product={product} />
            ))}
          </div>
        ) : (
          <p class="mt-4 text-center text-sm text-gray-500">
            おすすめ商品の情報を準備中です。
          </p>
        )
      }
      <div class="mt-8 text-center">
        <a
          href="/products"
          class="text-sm font-medium text-coffee-600 hover:text-coffee-700"
        >
          商品を見る →
        </a>
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="py-16">
    <div class="mx-auto max-w-content px-4">
      <h2 class="text-center text-2xl font-bold text-gray-900">お知らせ</h2>
      {
        latestNews.length > 0 ? (
          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {latestNews.map((news) => (
              <NewsCard news={news} />
            ))}
          </div>
        ) : (
          <p class="mt-4 text-center text-sm text-gray-500">
            お知らせの情報を準備中です。
          </p>
        )
      }
      <div class="mt-8 text-center">
        <a
          href="/news"
          class="text-sm font-medium text-coffee-600 hover:text-coffee-700"
        >
          お知らせを見る →
        </a>
      </div>
    </div>
  </section>

  <!-- Instagram -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-content px-4">
      <h2 class="text-center text-2xl font-bold text-gray-900">Instagram</h2>
      <p class="mt-2 text-center text-sm text-gray-500">
        最新情報は Instagram でも発信しています
      </p>
      <div class="mt-8">
        <!-- TODO: YOUR_BEHOLD_FEED_ID を Behold で作成したフィード ID に差し替えてください -->
        <div data-behold-id="YOUR_BEHOLD_FEED_ID"></div>
        <script src="https://w.behold.so/widget.js" type="module"></script>
      </div>
      <div class="mt-8 text-center">
        <a
          href="https://www.instagram.com/hakodate_mameichi"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-coffee-600 hover:text-coffee-700"
        >
          Instagram を見る →
        </a>
      </div>
    </div>
  </section>

  <!-- Access snippet -->
  <section class="py-16">
    <div class="mx-auto max-w-content px-4 text-center">
      <h2 class="text-2xl font-bold text-gray-900">アクセス</h2>
      <p class="mt-4 text-gray-600">〒040-0011 北海道函館市本町31-35</p>
      <p class="mt-1 text-sm text-gray-500">
        函館市電2系統 中央病院前駅 徒歩3分
      </p>
      <a
        href="/access"
        class="mt-6 inline-block rounded-md border border-coffee-600 px-6 py-3 text-sm font-medium text-coffee-600 transition-colors hover:bg-coffee-600 hover:text-white"
      >
        アクセス詳細を見る
      </a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="ギャラリー"
  description="焙煎工房 函館豆壱の店舗・商品・焙煎風景などの写真ギャラリー。"
>
  <section class="py-16">
    <div class="mx-auto max-w-content px-4">
      <h1 class="text-3xl font-bold text-gray-900">ギャラリー</h1>

      <!-- Gallery grid placeholder -->
      <div class="mt-8">
        <p class="text-sm text-gray-500">
          ※ microCMS 連携後、写真がグリッド表示されます。
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
